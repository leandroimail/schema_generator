# Example .env file for schema_matching project
# Copy this file to .env and fill in your actual API keys and settings

# LLM (Language Model) settings with reasoner
# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-pro-preview-05-06
LLM_GEMINI_IS_REASONER=true

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4.1-mini

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL_NAME=deepseek-reasoner

# LLM (Language Model - without reasoner) settings
# Uncomment and set as needed
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL_NAME=gemini-2.5-flash-preview-04-17
# LLM_GEMINI_IS_REASONER=false

# OpenAI PARSE API
OPENAI_PARSE_JSON_API_KEY=your_openai_parse_json_api_key_here
OPENAI_PARSE_JSON_MODEL_NAME=gpt-4.1-nano

# Request rate per second
LLM_REQUESTS_PER_SECOND=250
